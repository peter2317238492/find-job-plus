\NeedsTeXFormat{LaTeX2e}[1994/06/01]
\ProvidesPackage{NotoSansSC_external}[2026/05/03 Noto Sans SC CJK support]

\RequirePackage{fontspec}
\RequirePackage{xeCJK}

% Optional private local font helper. Copy this file and NotoSansSC-Regular.otf /
% NotoSansSC-Bold.otf into a generated workspace under work/common/ only when
% the font license has been reviewed. Do not commit font files to this package.
\defaultfontfeatures{Path = common/fonts/NotoSansSC/, Mapping=tex-text}

\setCJKmainfont[
  BoldFont=NotoSansSC-Bold.otf,
  ItalicFont=NotoSansSC-Regular.otf
]{NotoSansSC-Regular.otf}
\setCJKsansfont{NotoSansSC-Bold.otf}
\setCJKmonofont{NotoSansSC-Regular.otf}

\setCJKfamilyfont{zhregular}{NotoSansSC-Regular.otf}
\setCJKfamilyfont{zhbold}{NotoSansSC-Bold.otf}
\newcommand*{\songti}{\CJKfamily{zhregular}}
\newcommand*{\heiti}{\CJKfamily{zhbold}}
